{
  "name": "editor-spotlighter",
  "displayName": "Editor Spotlighter",
  "description": "フォーカスしたエディタカラムが自動で広がり、他が縮む。画面サイズに応じてアクティブカラム数も自動調整。",
  "publisher": "tsukamoto",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "editorSpotlighter",
          "title": "Editor Spotlighter",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "editorSpotlighter": [
        {
          "id": "editorSpotlighter.tabList",
          "name": "Tabs"
        },
        {
          "id": "editorSpotlighter.remoteView",
          "name": "Remote",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ],
      "view/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "when": "view == editorSpotlighter.tabList",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "editorSpotlighter.closeTab",
          "when": "view == editorSpotlighter.tabList && viewItem == tab",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Editor Spotlighter",
      "properties": {
        "editorSpotlighter.totalColumns": {
          "type": "number",
          "default": 4,
          "description": "総カラム数"
        },
        "editorSpotlighter.minColumnWidth": {
          "type": "number",
          "default": 850,
          "minimum": 100,
          "description": "1カラムの最小快適幅（px）。ウィンドウ幅をこの値で割ってアクティブカラム数を自動決定します"
        },
        "editorSpotlighter.fullWidthThreshold": {
          "type": "number",
          "default": 3000,
          "description": "この幅（px）以上のウィンドウでは全カラム等間隔で表示します"
        },
        "editorSpotlighter.activeRatio": {
          "type": "number",
          "default": 0.35,
          "description": "アクティブカラムの幅比率"
        },
        "editorSpotlighter.inactiveRatio": {
          "type": "number",
          "default": 0.1,
          "description": "非アクティブカラムの幅比率"
        },
        "editorSpotlighter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "有効/無効"
        },
        "editorSpotlighter.openTabBesideActive": {
          "type": "boolean",
          "default": true,
          "description": "新しいタブをアクティブなタブの右隣に開く（VSCodeの workbench.editor.openPositioning を制御）"
        },
        "editorSpotlighter.disablePreviewMode": {
          "type": "boolean",
          "default": false,
          "description": "プレビューモードを無効にして常に新しいタブで開く（VSCodeの workbench.editor.enablePreview を制御）"
        },
        "editorSpotlighter.remoteView.tunnelDomain": {
          "type": "string",
          "default": "",
          "description": "Cloudflare Tunnelのドメイン（例: itsudemo-issho.st-labo.app）。設定するとQRコードがこのドメインのURLで生成されます"
        },
        "editorSpotlighter.remoteView.enabled": {
          "type": "boolean",
          "default": false,
          "description": "モバイルリモートビューを有効にする"
        },
        "editorSpotlighter.remoteView.port": {
          "type": "number",
          "default": 19280,
          "description": "リモートビューのポート番号"
        }
      }
    },
    "commands": [
      {
        "command": "editorSpotlighter.toggle",
        "title": "Editor Spotlighter: Toggle"
      },
      {
        "command": "editorSpotlighter.setColumns",
        "title": "Editor Spotlighter: Set Column Count"
      },
      {
        "command": "editorSpotlighter.resetLayout",
        "title": "Editor Spotlighter: Reset Layout"
      },
      {
        "command": "editorSpotlighter.applyRecommendedSettings",
        "title": "Editor Spotlighter: Apply Recommended Settings"
      },
      {
        "command": "editorSpotlighter.alignLayout",
        "title": "Align Layout",
        "icon": {
          "light": "resources/icon.svg",
          "dark": "resources/icon.svg"
        }
      },
      {
        "command": "editorSpotlighter.closeTab",
        "title": "Editor Spotlighter: Close Tab",
        "icon": "$(close)"
      },
      {
        "command": "editorSpotlighter.focusTab",
        "title": "Editor Spotlighter: Focus Tab"
      },
      {
        "command": "editorSpotlighter.spContinue",
        "title": "Editor Spotlighter: Continue Session from Mobile"
      },
      {
        "command": "editorSpotlighter.startRemoteView",
        "title": "Editor Spotlighter: Start Remote View"
      },
      {
        "command": "editorSpotlighter.stopRemoteView",
        "title": "Editor Spotlighter: Stop Remote View"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  }
}
