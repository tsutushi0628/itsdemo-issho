{
  "name": "editor-spotlighter",
  "displayName": "Editor Spotlighter",
  "description": "フォーカスしたエディタカラムが自動で広がり、他が縮む。画面サイズに応じてアクティブカラム数も自動調整。",
  "publisher": "tsukamoto",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "editorSpotlighter",
          "title": "Editor Spotlighter",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "editorSpotlighter": [
        {
          "id": "editorSpotlighter.tabList",
          "name": "Tabs"
        },
        {
          "id": "editorSpotlighter.remoteView",
          "name": "Remote",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ],
      "view/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "when": "view == editorSpotlighter.tabList",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "editorSpotlighter.closeTab",
          "when": "view == editorSpotlighter.tabList && viewItem == tab",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Editor Spotlighter",
      "properties": {
        "editorSpotlighter.columns": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "列数（横方向のカラム数）。既定は4。コマンド「Choose Layout Preset」で行列をまとめて切り替えできます"
        },
        "editorSpotlighter.rows": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "段数（各列を縦に何分割するか）。既定は2。左端の編集用フル列はこの段数の対象外です"
        },
        "editorSpotlighter.fullHeightColumns": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "左端から何列を縦フル（1段）にするか。既定は1（左端1列を編集用に縦いっぱい使う）。0で全列を段数どおりに分割します"
        },
        "editorSpotlighter.totalColumns": {
          "type": "number",
          "default": 5,
          "description": "（非推奨）旧・総カラム数。現在は columns / rows / fullHeightColumns で指定します"
        },
        "editorSpotlighter.minColumnWidth": {
          "type": "number",
          "default": 460,
          "minimum": 100,
          "description": "アクティブ枠の最小許容幅（px）。エディタ領域幅とこの値からアクティブカラム数を自動決定します。サイドバーを開いたまま2カラムをアクティブにするには、編集領域（ウィンドウ幅−サイドバー幅−枠）に2枠＋覗き列が収まる値にします"
        },
        "editorSpotlighter.sidebarWidthWhenOpen": {
          "type": "number",
          "default": 230,
          "minimum": 0,
          "description": "プライマリサイドバーが開いているときに編集領域から差し引く幅（px）。実機のサイドバー幅に合わせて調整します。実値より大きめにすると列が崩れにくく、小さすぎると非アクティブ列が最小幅を割って崩れます"
        },
        "editorSpotlighter.maxActiveColumns": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "同時にアクティブにする列数の上限。ウィンドウを広げてもこの本数を超えてアクティブ化しません（0で上限なし）。最小許容幅だけでは広い画面で本数が増えるため、上限で頭を抑えます。fullWidthThreshold以上の等間隔表示には適用されません"
        },
        "editorSpotlighter.fullWidthThreshold": {
          "type": "number",
          "default": 3000,
          "description": "この幅（px）以上のウィンドウでは全カラム等間隔で表示します"
        },
        "editorSpotlighter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "有効/無効"
        },
        "editorSpotlighter.openTabBesideActive": {
          "type": "boolean",
          "default": true,
          "description": "新しいタブをアクティブなタブの右隣に開く（VSCodeの workbench.editor.openPositioning を制御）"
        },
        "editorSpotlighter.disablePreviewMode": {
          "type": "boolean",
          "default": false,
          "description": "プレビューモードを無効にして常に新しいタブで開く（VSCodeの workbench.editor.enablePreview を制御）"
        },
        "editorSpotlighter.remoteView.tunnelDomain": {
          "type": "string",
          "default": "",
          "description": "Cloudflare Tunnelのドメイン（例: itsudemo-issho.st-labo.app）。設定するとQRコードがこのドメインのURLで生成されます"
        },
        "editorSpotlighter.remoteView.enabled": {
          "type": "boolean",
          "default": false,
          "description": "モバイルリモートビューを有効にする"
        },
        "editorSpotlighter.remoteView.port": {
          "type": "number",
          "default": 19280,
          "description": "リモートビューのポート番号"
        },
        "editorSpotlighter.remoteView.password": {
          "type": "string",
          "default": "",
          "description": "リモートビューの接続パスワード。空のままにすると起動ごとに高エントロピーのワンタイムパスワードを自動生成し、QRに埋め込んでスキャン時に自動ログインします（推奨・起動ごとに失効）。固定値を設定するとQR画像に長期有効な秘密として埋め込まれるため、QRの撮影・画面共有に注意してください。"
        },
        "editorSpotlighter.remoteView.allowRemoteInput": {
          "type": "boolean",
          "default": true,
          "description": "リモート（スマホ）からのキーボード入力・クリック・タブ切替を許可します。閲覧専用にしたい場合はオフにしてください"
        },
        "editorSpotlighter.remoteView.bindAddress": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "リモートビューサーバの待受アドレス。既定はローカルのみ（トンネル経由向け・安全）。同一LANのスマホから直結する場合は 0.0.0.0 に変更。ただし LAN 直結は平文HTTP（TLS未対応）であり、同一ネットワーク上の第三者にパスワード・セッション・画面が盗聴され得る。可能ならトンネル（HTTPS）経由を推奨"
        }
      }
    },
    "commands": [
      {
        "command": "editorSpotlighter.toggle",
        "title": "Editor Spotlighter: Toggle"
      },
      {
        "command": "editorSpotlighter.setColumns",
        "title": "Editor Spotlighter: Set Column Count"
      },
      {
        "command": "editorSpotlighter.chooseLayoutPreset",
        "title": "Editor Spotlighter: Choose Layout Preset"
      },
      {
        "command": "editorSpotlighter.resetLayout",
        "title": "Editor Spotlighter: Reset Layout"
      },
      {
        "command": "editorSpotlighter.applyRecommendedSettings",
        "title": "Editor Spotlighter: Apply Recommended Settings"
      },
      {
        "command": "editorSpotlighter.alignLayout",
        "title": "Align Layout",
        "icon": {
          "light": "resources/icon.svg",
          "dark": "resources/icon.svg"
        }
      },
      {
        "command": "editorSpotlighter.closeTab",
        "title": "Editor Spotlighter: Close Tab",
        "icon": "$(close)"
      },
      {
        "command": "editorSpotlighter.focusTab",
        "title": "Editor Spotlighter: Focus Tab"
      },
      {
        "command": "editorSpotlighter.spContinue",
        "title": "Editor Spotlighter: Continue Session from Mobile"
      },
      {
        "command": "editorSpotlighter.startRemoteView",
        "title": "Editor Spotlighter: Start Remote View"
      },
      {
        "command": "editorSpotlighter.stopRemoteView",
        "title": "Editor Spotlighter: Stop Remote View"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  }
}
