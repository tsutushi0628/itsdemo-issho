{
  "name": "editor-spotlighter",
  "displayName": "Editor Spotlighter",
  "description": "フォーカスしたエディタカラムが自動で広がり、他が縮む。画面サイズに応じてアクティブカラム数も自動調整。",
  "publisher": "tsukamoto",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "editorSpotlighter",
          "title": "Editor Spotlighter",
          "icon": "$(layout)"
        }
      ]
    },
    "views": {
      "editorSpotlighter": [
        {
          "id": "editorSpotlighter.tabList",
          "name": "Tabs"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ],
      "view/title": [
        {
          "command": "editorSpotlighter.alignLayout",
          "when": "view == editorSpotlighter.tabList",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "editorSpotlighter.closeTab",
          "when": "view == editorSpotlighter.tabList && viewItem == tab",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Editor Spotlighter",
      "properties": {
        "editorSpotlighter.totalColumns": {
          "type": "number",
          "default": 4,
          "description": "総カラム数"
        },
        "editorSpotlighter.activeColumns": {
          "type": "number",
          "default": 4,
          "description": "同時にアクティブにするカラム数（画面が広いときは全部アクティブ）"
        },
        "editorSpotlighter.activeRatio": {
          "type": "number",
          "default": 0.35,
          "description": "アクティブカラムの幅比率"
        },
        "editorSpotlighter.inactiveRatio": {
          "type": "number",
          "default": 0.1,
          "description": "非アクティブカラムの幅比率"
        },
        "editorSpotlighter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "有効/無効"
        },
        "editorSpotlighter.openTabBesideActive": {
          "type": "boolean",
          "default": true,
          "description": "新しいタブをアクティブなタブの右隣に開く（VSCodeの workbench.editor.openPositioning を制御）"
        },
        "editorSpotlighter.disablePreviewMode": {
          "type": "boolean",
          "default": false,
          "description": "プレビューモードを無効にして常に新しいタブで開く（VSCodeの workbench.editor.enablePreview を制御）"
        },
        "editorSpotlighter.presets": {
          "type": "object",
          "default": {},
          "description": "解像度別プリセット"
        }
      }
    },
    "commands": [
      {
        "command": "editorSpotlighter.toggle",
        "title": "Editor Spotlighter: Toggle"
      },
      {
        "command": "editorSpotlighter.setColumns",
        "title": "Editor Spotlighter: Set Column Count"
      },
      {
        "command": "editorSpotlighter.resetLayout",
        "title": "Editor Spotlighter: Reset Layout"
      },
      {
        "command": "editorSpotlighter.applyRecommendedSettings",
        "title": "Editor Spotlighter: Apply Recommended Settings"
      },
      {
        "command": "editorSpotlighter.alignLayout",
        "title": "Align Layout",
        "icon": "$(layout)"
      },
      {
        "command": "editorSpotlighter.closeTab",
        "title": "Editor Spotlighter: Close Tab",
        "icon": "$(close)"
      },
      {
        "command": "editorSpotlighter.focusTab",
        "title": "Editor Spotlighter: Focus Tab"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
